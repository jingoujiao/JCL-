<Window x:Class="MinecraftLuanch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MinecraftLuanch"
        mc:Ignorable="d"
        Title="Minecraft 启动器" Height="600" Width="1000" MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="0" Width="140">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                
                <!-- 启动器 Logo -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⛏️" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="启动器" FontSize="11" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                
                <!-- 导航按钮 -->
                <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,10,0,0">
                    <Button x:Name="LaunchButton" Content="🚀 启动" 
                            Width="120" Height="38" Margin="0,8"
                            Background="#0078D4" Foreground="White"
                            BorderThickness="0" FontSize="13"
                            Click="LaunchButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button x:Name="DownloadButton" Content="📥 下载" 
                            Width="120" Height="38" Margin="0,8"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" FontSize="13"
                            Click="DownloadButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button x:Name="VersionsButton" Content="📦 版本" 
                            Width="120" Height="38" Margin="0,8"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" FontSize="13"
                            Click="VersionsButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button x:Name="AccountButton" Content="👤 账号" 
                            Width="120" Height="38" Margin="0,8"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" FontSize="13"
                            Click="AccountButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button x:Name="SettingsButton" Content="⚙️ 设置" 
                            Width="120" Height="38" Margin="0,8"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" FontSize="13"
                            Click="SettingsButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button x:Name="MoreButton" Content="ℹ️ 更多" 
                            Width="120" Height="38" Margin="0,8"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" FontSize="13"
                            Click="MoreButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                
                <!-- 底部信息 -->
                <StackPanel Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="v1.0.0" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 右侧内容区 -->
        <Border Grid.Column="1" Background="White" Margin="5" CornerRadius="8">
            <Grid>
                <!-- 启动界面 -->
                <Grid x:Name="LaunchPage" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 中央启动区域 -->
                    <Border Grid.Row="0" Background="#F9F9F9" CornerRadius="8" Margin="20" Padding="30">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
                            <TextBlock Text="🎮 Minecraft 启动器" FontSize="28" FontWeight="Bold" 
                                       Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                            
                            <!-- 已安装版本选择 -->
                            <TextBlock Text="选择游戏版本" Margin="0,0,0,8" Foreground="#555555" FontSize="13" HorizontalAlignment="Center"/>
                            <DockPanel LastChildFill="True" Margin="0,0,0,20" Width="400">
                                <Button x:Name="RefreshGameVersionsButton" Content="🔄" Width="45" Height="38" Margin="0,0,8,0" Click="RefreshVersions_Click" FontSize="14"/>
                                <ComboBox x:Name="GameVersion" MinHeight="38" VerticalContentAlignment="Center" Padding="10,5" BorderBrush="#DDDDDD" BorderThickness="1" SelectionChanged="GameVersion_SelectionChanged" FontSize="13"/>
                            </DockPanel>
                            
                            <!-- 启动按钮 -->
                            <Button x:Name="StartGame" Content="▶️ 开始游戏" MinHeight="50" Width="400"
                                    Background="#0078D4" Foreground="White" 
                                    BorderThickness="0" FontSize="16" FontWeight="Bold"
                                    Click="StartGame_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="20">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <!-- 进度条 -->
                            <Grid Margin="0,15,0,0" Width="400">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Grid.Column="0" x:Name="DownloadProgress" Height="8" Minimum="0" Maximum="100" Value="0" Foreground="#4CAF50"/>
                                <TextBlock Grid.Column="1" x:Name="ProgressText" Text="就绪" FontSize="12" Foreground="#666666" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- 下载界面 -->
                <Grid x:Name="DownloadPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 标题 -->
                    <TextBlock Grid.Row="0" Text="📥 下载游戏" FontSize="20" FontWeight="Bold" Margin="25,20,25,15" Foreground="#333333"/>
                    
                    <!-- 下载配置 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="25,0,25,20">
                            <!-- 版本类型 -->
                            <TextBlock Text="版本类型" Margin="0,0,0,8" Foreground="#555555" FontSize="13"/>
                            <ComboBox x:Name="VersionType" MinHeight="35" Margin="0,0,0,15" Padding="10,5" BorderBrush="#DDDDDD" BorderThickness="1" SelectionChanged="VersionType_SelectionChanged">
                                <ComboBoxItem Content="✨ 正式版（Release）" IsSelected="True"/>
                                <ComboBoxItem Content="🔬 测试版（Snapshot）"/>
                            </ComboBox>
                            
                            <!-- 选择版本 -->
                            <TextBlock Text="选择版本" Margin="0,0,0,8" Foreground="#555555" FontSize="13"/>
                            <DockPanel LastChildFill="True" Margin="0,0,0,15">
                                <Button x:Name="RefreshVersionsButton" Content="🔄 刷新" Width="70" Height="35" Margin="0,0,10,0" Click="RefreshVersionsButton_Click" FontSize="13"/>
                                <ComboBox x:Name="InstallVersion" MinHeight="35" VerticalContentAlignment="Center" Padding="10,5" BorderBrush="#DDDDDD" BorderThickness="1" IsEditable="True" IsTextSearchEnabled="True"/>
                            </DockPanel>
                            
                            <!-- 下载进度 -->
                            <Border Background="#F5F5F5" CornerRadius="6" Padding="15" Margin="0,10,0,15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" x:Name="DownloadProgressText" Text="等待下载..." FontSize="12" Foreground="#666666" Margin="0,0,0,8"/>
                                    <ProgressBar Grid.Row="1" x:Name="DownloadProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"/>
                                </Grid>
                            </Border>
                            
                            <!-- 安装按钮 -->
                            <Button x:Name="InstallVanillaButton" Content="📥 开始下载" MinHeight="45" 
                                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontSize="15" FontWeight="Bold"
                                    Click="InstallVanilla_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- 日志区域 -->
                    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="6" Margin="25,0,25,20" Padding="12" MaxHeight="150">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="📋 下载日志" FontSize="12" FontWeight="Bold" Foreground="#AAAAAA" Margin="0,0,0,8"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="LogBox" TextWrapping="Wrap" Background="Transparent" 
                                         Foreground="#CCCCCC" BorderThickness="0" 
                                         FontFamily="Consolas" FontSize="11"
                                         IsReadOnly="True" AcceptsReturn="True"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- 版本管理界面 -->
                <Grid x:Name="VersionsPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 标题和操作按钮 -->
                    <Grid Grid.Row="0" Margin="25,20,25,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="📦 版本管理" FontSize="20" FontWeight="Bold" Foreground="#333333"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="ImportVersionButton" Content="📥 导入版本" Width="100" Height="32" Margin="0,0,8,0"
                                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontSize="12"
                                    Click="ImportVersionButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="RefreshVersionsListButton" Content="🔄 刷新" Width="80" Height="32"
                                    Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="12"
                                    Click="RefreshVersionsListButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                    
                    <!-- 版本列表 -->
                    <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="6" Margin="25,0,25,20" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 版本列表 -->
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="VersionsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding VersionName}" FontSize="14" FontWeight="Bold" Foreground="#333333"/>
                                                        <TextBlock Text="{Binding VersionPath}" FontSize="11" Foreground="#999999" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                    
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,0,0">
                                                        <Button Content="📂" Width="35" Height="32" Margin="0,0,5,0"
                                                                Background="#FF9800" Foreground="White" BorderThickness="0" FontSize="14"
                                                                Click="OpenVersionFolder_Click" Tag="{Binding VersionName}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="✏️" Width="35" Height="32" Margin="0,0,5,0"
                                                                Background="#2196F3" Foreground="White" BorderThickness="0" FontSize="14"
                                                                Click="RenameVersion_Click" Tag="{Binding VersionName}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="🗑️" Width="35" Height="32"
                                                                Background="#F44336" Foreground="White" BorderThickness="0" FontSize="14"
                                                                Click="DeleteVersion_Click" Tag="{Binding VersionName}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <!-- 提示信息 -->
                            <TextBlock Grid.Row="1" Text="💡 提示：点击文件夹图标打开版本目录，点击编辑图标修改版本名称，点击删除图标删除版本" 
                                       FontSize="11" Foreground="#999999" Margin="0,10,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- 设置界面 -->
                <Grid x:Name="SettingsPage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="25">
                            <TextBlock Text="⚙️ 设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333333"/>
                            
                            <!-- 游戏目录设置 -->
                            <Border Background="#F5F5F5" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="📁 游戏目录" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333333"/>
                                    <TextBlock Text="当前目录：" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="CurrentGameRoot" FontSize="12" Foreground="#333333" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <DockPanel LastChildFill="True">
                                        <Button Content="浏览…" Width="70" Height="30" Margin="0,0,10,0" Click="BrowseRoot_Click" FontSize="12"/>
                                        <TextBox x:Name="GameRoot" TextWrapping="NoWrap" VerticalContentAlignment="Center" Padding="8,5" BorderBrush="#DDDDDD" BorderThickness="1" FontSize="12"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Java 设置 -->
                            <Border Background="#F5F5F5" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="☕ Java 版本" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333333"/>
                                    <TextBlock Text="选择 Java 路径（启动器会自动选择兼容版本）" FontSize="12" Foreground="#666666" Margin="0,0,0,8"/>
                                    <DockPanel LastChildFill="True" Margin="0,0,0,10">
                                        <Button x:Name="RefreshJavaButton" Content="🔄" Width="45" Height="30" Margin="0,0,8,0" Click="RefreshJava_Click" FontSize="14"/>
                                        <ComboBox x:Name="JavaPath" MinHeight="30" VerticalContentAlignment="Center" Padding="8,5" BorderBrush="#DDDDDD" BorderThickness="1" DisplayMemberPath="JavaPath" SelectedValuePath="JavaPath" FontSize="12"/>
                                    </DockPanel>
                                    <TextBlock Text="💡 提示：" FontSize="12" FontWeight="Bold" Foreground="#FF9800" Margin="0,5,0,3"/>
                                    <TextBlock Text="• 1.21+ 需要 Java 21" FontSize="11" Foreground="#666666"/>
                                    <TextBlock Text="• 1.17-1.20 需要 Java 17" FontSize="11" Foreground="#666666"/>
                                    <TextBlock Text="• 1.16 及以下需要 Java 8" FontSize="11" Foreground="#666666"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- 内存设置 -->
                            <Border Background="#F5F5F5" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="💾 内存分配" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333333"/>
                                    <TextBlock Text="最大内存 (MB)" FontSize="12" Foreground="#666666" Margin="0,0,0,8"/>
                                    <TextBox x:Name="MaxMemory" Text="4096" MinHeight="30" VerticalContentAlignment="Center" 
                                             Padding="8,5" BorderBrush="#DDDDDD" BorderThickness="1" Margin="0,0,0,8" FontSize="12"/>
                                    <TextBlock Text="💡 建议：轻量 2048MB / 中型 4096MB / 大型 8192MB" FontSize="11" Foreground="#999999"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- 其他设置 -->
                            <Border Background="#F5F5F5" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="🔧 其他设置" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333333"/>
                                    <CheckBox x:Name="FullScreen" Content="全屏模式启动" FontSize="12" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Button x:Name="SaveSettingsButton" Content="💾 保存设置" Width="130" Height="38" 
                                    Background="#4CAF50" Foreground="White" 
                                    BorderThickness="0" FontSize="13" FontWeight="Bold"
                                    HorizontalAlignment="Left" Click="SaveSettingsButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                
                <!-- 账号界面 -->
                <Grid x:Name="AccountPage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="25">
                            <TextBlock Text="👤 账号管理" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333333"/>
                            
                            <!-- 离线账号设置 -->
                            <Border Background="#F5F5F5" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="🎮 离线账号" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333333"/>
                                    <TextBlock Text="离线模式无需正版账号，输入昵称即可游戏" FontSize="12" Foreground="#666666" Margin="0,0,0,10"/>
                                    <TextBlock Text="离线昵称" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                                    <TextBox x:Name="PlayerName" MinHeight="35" VerticalContentAlignment="Center" 
                                             Padding="10,5" BorderBrush="#DDDDDD" BorderThickness="1" FontSize="13" Margin="0,0,0,10"/>
                                    <TextBlock Text="💡 提示：昵称仅用于离线模式，无法使用皮肤和正版服务器" FontSize="11" Foreground="#999999"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- 账号信息 -->
                            <Border Background="#E3F2FD" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="ℹ️ 当前账号信息" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1976D2"/>
                                    <TextBlock x:Name="CurrentAccountInfo" Text="模式：离线模式" FontSize="13" Foreground="#333333"/>
                                    <TextBlock x:Name="CurrentPlayerName" Text="昵称：未设置" FontSize="13" Foreground="#333333" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Button x:Name="SaveAccountButton" Content="💾 保存账号设置" Width="150" Height="38" 
                                    Background="#4CAF50" Foreground="White" 
                                    BorderThickness="0" FontSize="13" FontWeight="Bold"
                                    HorizontalAlignment="Left" Click="SaveAccountButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                
                <!-- 更多界面 -->
                <Grid x:Name="MorePage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="25">
                            <TextBlock Text="ℹ️ 更多" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333333"/>
                            
                            <!-- 公告栏 -->
                            <Border Background="#E3F2FD" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="📢 公告" FontSize="14" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,8"/>
                                    <Border Grid.Row="1" Background="White" CornerRadius="4" Padding="12">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                                            <TextBlock x:Name="AnnouncementText" TextWrapping="Wrap" Foreground="#333333" FontSize="12" LineHeight="20"/>
